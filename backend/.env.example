APP_ENV=dev
# Comma-separated allowed origins for CORS (your frontend URL)
CORS_ORIGINS=http://localhost:5173

# Data provider: yfinance | indian_api | alpaca
DATA_PROVIDER=yfinance
# Base URL of a deployed Indian-Stock-Market-API instance (optional)
INDIAN_API_BASE_URL=

# Alpaca is US/crypto ONLY (optional). Regenerate your keys and put them HERE, never in code.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

DB_URL=sqlite:///./trading.db
STARTING_CASH=1000000
RISK_PER_TRADE_PCT=0.5
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=3.0
BENCHMARK=^NSEI
